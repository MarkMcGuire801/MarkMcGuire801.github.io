  <!-- ═══════════════════════════════
       JAVASCRIPT
       Handles lightbox image expand,
       lightbox navigation, and
       slideshow navigation
  ═══════════════════════════════ -->
  <script>

    /* ── Lightbox ──
       Clicking a grid image opens it
       fullscreen in the lightbox overlay */

    /* Collect all grid images into an array for navigation */
    const gridImages = Array.from(document.querySelectorAll('.grid-img'));
    let currentLightboxIndex = 0;

    /* Add click listener to every grid image */
    gridImages.forEach((img, index) => {
      img.addEventListener('click', () => openLightbox(index));
    });

    /* openLightbox(index)
       index: number — the position of the clicked image in the grid
       Opens the lightbox and displays the image at the given index */
    function openLightbox(index) {
      currentLightboxIndex = index;
      const img = gridImages[index];
      document.getElementById('lightbox-img').src = img.src;
      document.getElementById('lightbox-img').alt = img.alt;
      document.getElementById('lightbox-caption').textContent =
        img.closest('.grid-img-wrap').querySelector('.img-caption').textContent;
      document.getElementById('lightbox').classList.add('active');
    }

    /* Closes the lightbox by removing the active class */
    function closeLightbox() {
      document.getElementById('lightbox').classList.remove('active');
    }

    /* changeSlide(direction)
       direction: -1 for previous, 1 for next
       Navigates to the previous or next image in the lightbox
       wraps around when reaching the first or last image */
    function changeSlide(direction) {
      currentLightboxIndex = (currentLightboxIndex + direction + gridImages.length) % gridImages.length;
      openLightbox(currentLightboxIndex);
    }

    /* Close lightbox when clicking outside the image */
    document.getElementById('lightbox').addEventListener('click', function(e) {
      if (e.target === this) closeLightbox();
    });


    /* ── Slideshow ──
       Add your image paths to the slides array below.
       The slideshow cycles through them with
       previous and next buttons */

    /* Update these paths and alt text to match your actual image files */
    const slides = [
      { src: '../assets/images/placeholder.png', alt: 'Slide 1' },
      { src: '../assets/images/placeholder.png', alt: 'Slide 2' },
      { src: '../assets/images/placeholder.png', alt: 'Slide 3' },
    ];

    let currentSlide = 0;

    /* Updates the displayed slide image and counter text */
    function updateSlideshow() {
      document.getElementById('slideshow-img').src = slides[currentSlide].src;
      document.getElementById('slideshow-img').alt = slides[currentSlide].alt;
      document.getElementById('slide-counter').textContent =
        (currentSlide + 1) + ' / ' + slides.length;
    }

    /* Goes to the previous slide — wraps around to the last slide */
    function prevSlide() {
      currentSlide = (currentSlide - 1 + slides.length) % slides.length;
      updateSlideshow();
    }

    /* Goes to the next slide — wraps around to the first slide */
    function nextSlide() {
      currentSlide = (currentSlide + 1) % slides.length;
      updateSlideshow();
    }

    /* Initialize the slideshow on page load */
    updateSlideshow();

  </script>

